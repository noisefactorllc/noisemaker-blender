{
  "name": "Oil Paint",
  "namespace": "filter",
  "func": "oilPaint",
  "tags": [
    "blur",
    "edges",
    "artist"
  ],
  "paramAliases": {},
  "globals": {
    "mode": {
      "type": "int",
      "default": 1,
      "define": "MODE",
      "choices": {
        "facet": 0,
        "daubs": 1,
        "dryBrush": 2,
        "fresco": 3,
        "knife": 4,
        "sponge": 5
      }
    },
    "size": {
      "type": "float",
      "default": 6,
      "uniform": "size",
      "min": 1,
      "max": 12
    },
    "detail": {
      "type": "float",
      "default": 50,
      "uniform": "detail",
      "min": 0,
      "max": 100
    },
    "texture": {
      "type": "float",
      "default": 20,
      "uniform": "textureAmount",
      "min": 0,
      "max": 100
    },
    "seed": {
      "type": "int",
      "default": 1,
      "uniform": "seed",
      "min": 1,
      "max": 100
    }
  },
  "passes": [
    {
      "name": "flatten",
      "program": "oilFlatten",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "_paintTmp"
      },
      "uniforms": {
        "size": "size"
      }
    },
    {
      "name": "post",
      "program": "oilPost",
      "inputs": {
        "inputTex": "inputTex",
        "flatTex": "_paintTmp"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "size": "size",
        "detail": "detail",
        "textureAmount": "textureAmount",
        "seed": "seed"
      }
    }
  ],
  "textures": {
    "_paintTmp": {
      "width": "input",
      "height": "input",
      "format": "rgba8unorm"
    }
  }
}
